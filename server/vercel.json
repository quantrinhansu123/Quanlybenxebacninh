{
  "version": 2,
  "builds": [
    { "src": "api/auth.ts", "use": "@vercel/node" },
    { "src": "api/fleet.ts", "use": "@vercel/node" },
    { "src": "api/dispatch.ts", "use": "@vercel/node" },
    { "src": "api/analytics.ts", "use": "@vercel/node" },
    { "src": "api/chat.ts", "use": "@vercel/node" },
    { "src": "api/config.ts", "use": "@vercel/node" },
    { "src": "api/webhooks.ts", "use": "@vercel/node" },
    { "src": "api/data.ts", "use": "@vercel/node" },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth(.*)", "dest": "api/auth.ts" },
    { "src": "/api/users(.*)", "dest": "api/auth.ts" },

    { "src": "/api/vehicles(.*)", "dest": "api/fleet.ts" },
    { "src": "/api/drivers(.*)", "dest": "api/fleet.ts" },
    { "src": "/api/operators(.*)", "dest": "api/fleet.ts" },
    { "src": "/api/vehicle-badges(.*)", "dest": "api/fleet.ts" },
    { "src": "/api/vehicle-types(.*)", "dest": "api/fleet.ts" },

    { "src": "/api/dispatch(.*)", "dest": "api/dispatch.ts" },
    { "src": "/api/invoices(.*)", "dest": "api/dispatch.ts" },
    { "src": "/api/violations(.*)", "dest": "api/dispatch.ts" },
    { "src": "/api/service-charges(.*)", "dest": "api/dispatch.ts" },

    { "src": "/api/dashboard(.*)", "dest": "api/analytics.ts" },
    { "src": "/api/reports(.*)", "dest": "api/analytics.ts" },

    { "src": "/api/chat(.*)", "dest": "api/chat.ts" },

    { "src": "/api/schedules(.*)", "dest": "api/config.ts" },
    { "src": "/api/shifts(.*)", "dest": "api/config.ts" },
    { "src": "/api/routes(.*)", "dest": "api/config.ts" },
    { "src": "/api/locations(.*)", "dest": "api/config.ts" },
    { "src": "/api/provinces(.*)", "dest": "api/config.ts" },
    { "src": "/api/services(.*)", "dest": "api/config.ts" },
    { "src": "/api/service-formulas(.*)", "dest": "api/config.ts" },

    { "src": "/api/webhooks(.*)", "dest": "api/webhooks.ts" },
    { "src": "/api/integrations(.*)", "dest": "api/webhooks.ts" },
    { "src": "/api/upload(.*)", "dest": "api/webhooks.ts" },
    { "src": "/api/operation-notices(.*)", "dest": "api/webhooks.ts" },

    { "src": "/api/quanly-data(.*)", "dest": "api/data.ts" },
    { "src": "/(.*)", "dest": "api/index.ts" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization" }
      ]
    }
  ]
}
